# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET_NAME=speach-analyzer

# Transcription
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# AI API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# LLM Client (Sales Analyzer)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
STORAGE_DIR=/tmp/speak-right
GUEST_MAX_UPLOAD_MB=50

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Supabase Service Role Key (admin access - DO NOT expose to clients)
# Get this from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PostgreSQL Database Connection
# Format: postgresql://postgres:PASSWORD@db.your-project.supabase.co:5432/postgres
# Note: URL-encode special characters in password (@ becomes %40)
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# Optional: For future enhancements
# REDIS_URL=redis://localhost:6379/0
