# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore

.gcloudignore
.git
.gitignore
*.pyc
*.pyo
*.pyd
__pycache__
.pytest_cache
.coverage
htmlcov
dist/
build/
*.egg-info
.env
.env.local
.venv
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation
*.md
docs/

# Tests
tests/
test_*.py
*_test.py

# Temporary files
*.log
tmp/
temp/
